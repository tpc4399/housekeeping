<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.housekeeping.admin.mapper.OrderPhotosMapper">
    <insert id="saveBatch">
        insert into order_photos
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (null,#{item.number},#{item.photoUrl},#{item.evaluate},#{item.yes},#{item.resultPhotoUrls},#{item.result},#{item.resultTime})
        </foreach>
    </insert>

    <update id="keyWorkReturn">
        UPDATE order_photos t
        SET t.yes = 1, t.result_photo_urls = #{dto.resultPhotoUrls}, t.result = #{dto.result}, t.result_time = #{now}
        WHERE t.id = #{dto.orderPhotosId}
    </update>
    <select id="getByOrderNumber" resultType="com.housekeeping.admin.entity.OrderPhotos">
        SELECT t.*
        FROM housekeeping.order_photos t
        WHERE `number` = #{number}
    </select>
    <select id="listByNumber" resultType="com.housekeeping.admin.entity.OrderPhotos">
        SELECT t.*
        FROM housekeeping.order_photos t
        WHERE `number` = #{number}
    </select>

</mapper>
